# Required for live AI generation. Without it the API streams a
# deterministic mock letter so the system stays usable end-to-end.
OPENAI_API_KEY=

# Optional. Defaults to gpt-4o-mini.
OPENAI_MODEL=gpt-4o-mini

# Optional. Defaults to 3001.
PORT=3001

# Optional. Defaults to http://localhost:5173 in development.
# Set this to the deployed web origin in production. Use "*" only for
# fully-public APIs.
CORS_ORIGIN=http://localhost:5173
